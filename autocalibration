void auto_calibrate_tool(uint8_t tool) {
    current_tool = tool;
    selector_set(current_tool);

    // known test extrusion
    requested_e = 10.0f;  // 10 mm
    begin_extrude();
    plan_extruder_move(requested_e);
    end_extrude();        // measured_e computed inside

    // flow_factor[current_tool] updated automatically
}

void process_extended_gcode(char *line) {

    if (starts_with(line, "M702")) {  // auto-calibrate current tool
        auto_calibrate_tool(current_tool);
        return;
    }
}
