[printer]
name = Nano_Selector_7E_1H
bed_shape = 0x0,200x0,200x200,0x200
nozzle_diameter = 0.4
extruders = 7

[physical_printer]
host_type = marlin

[extruder_0]
nozzle_diameter = 0.4
material = PLA
shared_nozzle = 1

[extruder_1]
nozzle_diameter = 0.4
material = PLA
shared_nozzle = 1

[extruder_2]
nozzle_diameter = 0.4
material = PLA
shared_nozzle = 1

[extruder_3]
nozzle_diameter = 0.4
