[printer:custom_gcode]
start_gcode = M104 S[first_layer_temperature]; M109 S[first_layer_temperature]
end_gcode = M104 S0

toolchange_gcode = 
  ; Tool change to [next_extruder]
  T[next_extruder]
  G4 P500 ; wait 500 ms for selector
