diff --git a/cpu_map.h b/cpu_map.h
index 1234567..89abcde 100644
--- a/cpu_map.h
+++ b/cpu_map.h
@@ -1,3 +1,4 @@
+// nano3d6material CPU map with kill-ring pins
 #ifndef cpu_map_h
 #define cpu_map_h
 
@@ -40,6 +41,22 @@
 // Existing pin definitions for X/Y/Z, extruder, selector, heater, thermistor, endstops...
 // (unchanged)
 
+// ---------------------------------------------------------------------------
+// Kill-ring safety switches
+// ---------------------------------------------------------------------------
+// We use only pins that are not mapped elsewhere in nano3d6material:
+//  - A4 (PC4)  : free (I2C SDA if unused)
+//  - A5 (PC5)  : free (I2C SCL if unused)
+//  - D0 (PD0)  : serial RX (safe during print if host not streaming)
+//  - D1 (PD1)  : serial TX (same caveat)
+//  - A6 (ADC6) : analog-only input, perfect for switch
+//  - A7 (ADC7) : analog-only input, perfect for switch
+
+#define KILL0_PIN   A4
+#define KILL1_PIN   A5
+#define KILL2_PIN   0    // D0
+#define KILL3_PIN   1    // D1
+#define KILL4_PIN   A6
+#define KILL5_PIN   A7
 
 #endif // cpu_map_h
