diff --git a/gcode.c b/gcode.c
index 5678901..cdef012 100644
--- a/gcode.c
+++ b/gcode.c
@@ -1,6 +1,8 @@
 #include "gcode.h"
 #include "system.h"
 #include "report.h"
+#include "grbl.h"
+
 // Existing includes...
 
 void gcode_execute_line(char *line)
@@ -45,6 +47,14 @@ void gcode_execute_line(char *line)
         case 104:
             gcode_M104(); // example: set hotend temp
             break;
+        case 810:
+            gcode_M810();
+            break;
+        case 811:
+            gcode_M811();
+            break;
+
         // other M-codes...
@@ -120,3 +130,35 @@ void gcode_M104(void)
     // existing implementation...
 }
+
+// ---------------------------------------------------------------------------
+// M810: report kill-ring status
+// ---------------------------------------------------------------------------
+
+void gcode_M810(void)
+{
+    uint8_t active = kill_triggered();
+    if (active) {
+        report_message("KILL-RING: TRIGGERED");
+    } else {
+        report_message("KILL-RING: OK");
+    }
+}
+
+// ---------------------------------------------------------------------------
+// M811: clear kill latch (only if all switches released)
+// ---------------------------------------------------------------------------
+
+void gcode_M811(void)
+{
+    if (kill_triggered()) {
+        report_message("KILL-RING: STILL ACTIVE");
+        return;
+    }
+
+    kill_clear_latch();
+
+    if (sys.state == STATE_IDLE) {
+        report_message("KILL-RING: CLEARED");
+    } else {
+        report_message("KILL-RING: ALARM STILL SET");
+    }
+}
