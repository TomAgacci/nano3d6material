diff --git a/system.c b/system.c
index 3456789..abcde90 100644
--- a/system.c
+++ b/system.c
@@ -1,6 +1,7 @@
 #include "system.h"
 #include "cpu_map.h"
 #include "planner.h"
+#include "report.h"
 #include "heater.h"
 #include "grbl.h"
 
@@ -12,6 +13,55 @@
 // Existing system state, init, reset, etc.
 // ---------------------------------------------------------------------------
 
+// ---------------------------------------------------------------------------
+// Kill-ring safety implementation
+// ---------------------------------------------------------------------------
+
+static const uint8_t kill_pins[] = {
+    KILL0_PIN, KILL1_PIN, KILL2_PIN,
+    KILL3_PIN, KILL4_PIN, KILL5_PIN
+};
+
+static volatile uint8_t kill_latched = 0;
+
+void kill_init(void)
+{
+    for (uint8_t i = 0; i < sizeof(kill_pins); i++) {
+        pinMode(kill_pins[i], INPUT_PULLUP);
+    }
+}
+
+uint8_t kill_triggered(void)
+{
+    for (uint8_t i = 0; i < sizeof(kill_pins); i++) {
+        if (digitalRead(kill_pins[i]) == LOW) {
+            return 1;
+        }
+    }
+    return 0;
+}
+
+static void kill_emergency_stop(void)
+{
+    kill_latched = 1;
+
+    // Stop motion
+    planner_kill_all_motions();
+    st_go_idle();
+
+    // Disable heaters
+    heater_disable_all();
+
+    // Put GRBL into alarm state
+    sys.state = STATE_ALARM;
+    report_alarm_message(ALARM_HARD_LIMIT);
+}
+
+void kill_poll(void)
+{
+    if (kill_latched) return;
+    if (kill_triggered()) kill_emergency_stop();
+}
+
 void system_init(void)
 {
     // Existing init code...
@@ -19,6 +69,9 @@ void system_init(void)
     // planner_init();
     // heater_init();
 
+    // Initialize kill-ring pins
+    kill_init();
+
     // ...
 }
 
@@ -26,6 +79,18 @@ void system_reset(void)
 {
     // Existing reset logic...
     // sys.state = STATE_IDLE;
+
+    // Clear kill latch only if all switches are released
+    kill_clear_latch();
+}
+
+void kill_clear_latch(void)
+{
+    if (!kill_triggered()) {
+        kill_latched = 0;
+        if (sys.state == STATE_ALARM) {
+            sys.state = STATE_IDLE;
+        }
+    }
 }
